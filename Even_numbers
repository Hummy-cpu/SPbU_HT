#r "nuget: NUnit"
#r "nuget: FsUnit"
#r "nuget: Microsoft.NET.Test.Sdk"
#r "nuget: FsCheck"
#r "nuget: FsCheck.NUnit"

open System
open NUnit.Framework
open FsUnit
open FsCheck

let countEvenFilter list =
    list |> List.filter (fun x -> x % 2 = 0) |> List.length

let countEvenMap list =
    list |> List.map (fun x -> if x % 2 = 0 then 1 else 0) |> List.sum

let countEvenFold list =
    list |> List.fold (fun acc x -> if x % 2 = 0 then acc + 1 else acc) 0

[<Test>]
let ``3 are equivalent`` () =
    let prop (list: int list) =
        countEvenFilter list = countEvenMap list &&
        countEvenFilter list = countEvenFold list
    
    Check.Quick prop

[<Test>]
let ``empty list`` () =
    countEvenFilter [] |> should equal 0

[<Test>]
let ``mixed numbers`` () =
    let list = [1; 2; 3; 4; 5; 6]
    countEvenFilter list |> should equal 3

[<Test>]
let ``all odd`` () =
    let list = [1; 3; 5; 7]
    countEvenFilter list |> should equal 0

[<Test>]
let ``all even`` () =
    let list = [2; 4; 6; 8]
    countEvenFilter list |> should equal 4

[<Test>]
let ``with negatives`` () =
    let list = [-2; -1; 0; 1; 2]
    countEvenFilter list |> should equal 3 
